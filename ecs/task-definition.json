{
  "family": "tracking-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::581979856637:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::581979856637:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "tracking-service",
      "image": "IMAGE_URI",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp",
          "appProtocol": "http"

        },
        {
          "containerPort": 4318,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "prod"
        }
      ],
      "secrets": [
        {
          "name": "SPRING_DATASOURCE_URL",
          "valueFrom": "arn:aws:ssm:us-east-2:581979856637:parameter/SPRING_DATASOURCE_URL_2"
        },
        {
          "name": "SPRING_DATASOURCE_USERNAME",
          "valueFrom": "arn:aws:ssm:us-east-2:581979856637:parameter/SPRING_DATASOURCE_USERNAME_2"
        },
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "valueFrom": "arn:aws:ssm:us-east-2:581979856637:parameter/SPRING_DATASOURCE_PASSWORD_2"
        },
        {
          "name": "SPRING_KAFKA_BOOTSTRAP_SERVERS",
          "valueFrom": "arn:aws:ssm:us-east-2:581979856637:parameter/SPRING_KAFKA_BOOTSTRAP_SERVERS"
        },
        {
          "name": "SPRING_KAFKA_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-2:581979856637:parameter/SPRING_KAFKA_API_KEY"
        },
        {
          "name": "SPRING_KAFKA_API_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-2:581979856637:parameter/SPRING_KAFKA_API_SECRET"
        },
        {
          "name": "SPRING_SCHEMA_REGISTRY_URL",
          "valueFrom": "arn:aws:ssm:us-east-2:581979856637:parameter/SPRING_SCHEMA_REGISTRY_URL"
        },
        {
          "name": "SPRING_SCHEMA_REGISTRY_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-2:581979856637:parameter/SPRING_SCHEMA_REGISTRY_API_KEY"
        },
        {
          "name": "SPRING_SCHEMA_REGISTRY_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-2:581979856637:parameter/SPRING_SCHEMA_REGISTRY_SECRET"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tracking-service",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "tracking-service",
          "awslogs-create-group": "true"
        }
      }
    },
    {
      "name": "otel-collector",
      "image": "IMAGE_URI",
      "essential": true,
      "command": [
        "--config=/etc/ecs/otel-collector-config.yaml"
      ],
      "secrets": [
        {
          "name": "SPRING_PROMETHEUS_URL",
          "valueFrom": "arn:aws:ssm:us-east-2:581979856637:parameter/SPRING_PROMETHEUS_URL"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tracking-otel-collector",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "otel-collector",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}